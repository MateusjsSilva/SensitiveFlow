<Project>
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <WarningsAsErrors />
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <Authors>LGPD.NET Contributors</Authors>
    <Company>LGPD.NET</Company>
    <Copyright>Copyright © 2026 LGPD.NET Contributors</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/lgpd-dotnet/lgpd-dotnet</PackageProjectUrl>
    <RepositoryUrl>https://github.com/lgpd-dotnet/lgpd-dotnet</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>lgpd;anpd;privacidade;dados-pessoais;dotnet;csharp;compliance</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <Version>1.0.0-preview.1</Version>
  </PropertyGroup>
</Project>

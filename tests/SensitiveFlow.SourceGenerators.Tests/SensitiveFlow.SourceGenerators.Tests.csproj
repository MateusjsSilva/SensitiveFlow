<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <IsPublishable>false</IsPublishable>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="FluentAssertions" />
    <ProjectReference Include="..\..\src\SensitiveFlow.Core\SensitiveFlow.Core.csproj" />
    <!--
      Reference the generator as an analyzer so it actually runs against this test project.
      ReferenceOutputAssembly="false" prevents the generator's runtime types (which target
      netstandard2.0 with Roslyn dependencies) from leaking into the test project's compile graph.
    -->
    <ProjectReference Include="..\..\src\SensitiveFlow.SourceGenerators\SensitiveFlow.SourceGenerators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>
</Project>
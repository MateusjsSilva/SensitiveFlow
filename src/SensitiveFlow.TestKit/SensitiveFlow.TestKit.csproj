<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageDescription>Conformance test suite for IAuditStore and ITokenStore implementations. Use from test projects to validate store contracts.</PackageDescription>
    <!-- Test method names are self-documenting and we don't want to require XML doc on each [Fact] method. -->
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <IsTestProject>false</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="xunit" />
    <PackageReference Include="FluentAssertions" />
    <ProjectReference Include="..\SensitiveFlow.Core\SensitiveFlow.Core.csproj" />
  </ItemGroup>

</Project>
